# Database
DATABASE_URL="postgresql://sailor:sailor@localhost:5432/sailor?schema=public"

# JWT (use long random string in production)
JWT_SECRET="change-me-in-production-min-32-chars"
JWT_EXPIRES_IN="7d"

# Iframe token (optional: uses JWT_SECRET if not set)
IFRAME_TOKEN_SECRET=""
IFRAME_TOKEN_EXPIRY_SECONDS=600

# CKX base URL (where Sailor API calls CKX to create/release sessions)
CKX_BASE_URL="http://localhost:3000"
CKX_API_KEY=""

# Default runtime for CKX (single-node dev). In production, orchestrator provides per-session endpoints.
CKX_DEFAULT_VNC_HOST=remote-desktop
CKX_DEFAULT_VNC_PORT=6901
CKX_DEFAULT_VNC_PASSWORD=bakku-the-wizard
CKX_DEFAULT_SSH_HOST=remote-terminal
CKX_DEFAULT_SSH_PORT=22
CKX_DEFAULT_SSH_USER=candidate
CKX_DEFAULT_SSH_PASSWORD=password

# Public URL of Sailor API (for building examUrl in create session)
SAILOR_API_PUBLIC_URL=http://localhost:4000

# App
PORT=4000
NODE_ENV=development
